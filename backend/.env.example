# PostgreSQL connection string
# Local development format: postgresql://username:password@localhost:5432/documents_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/documents_db

# JWT signing secret. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# RabbitMQ connection string for Celery (broker)
# Local development format: amqp://guest:guest@localhost:5672//
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//

# OpenAI API key, used for the Vision LLM document extraction step
OPENAI_API_KEY=sk-replace_with_your_real_key